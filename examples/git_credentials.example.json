{
  "_comment": "Map hostnames to SSH key file paths",
  "_comment2": "This file should NOT be committed to version control",
  "_comment3": "Add this file to your .gitignore",
  "_comment_windows": "Windows: use PuTTY .ppk format keys (requires plink + Pageant)",
  "_comment_unix": "macOS/Linux: use OpenSSH format keys (e.g., id_ed25519, id_rsa)",

  "_examples_windows": {
    "github.com": "C:\\Users\\username\\.ssh\\github_key.ppk",
    "gitlab.com": "C:\\Users\\username\\.ssh\\gitlab_key.ppk",
    "bitbucket.org": "C:\\Users\\username\\.ssh\\bitbucket_key.ppk",
    "git.company.com": "C:\\keys\\company_deploy.ppk",
    "ssh://git.internal.corp": "C:\\keys\\internal_key.ppk",
    "dev.azure.com": "C:\\Users\\username\\.ssh\\azure_key.ppk"
  },

  "_examples_unix": {
    "github.com": "/home/username/.ssh/id_ed25519",
    "gitlab.com": "/home/username/.ssh/gitlab_rsa",
    "bitbucket.org": "/home/username/.ssh/id_rsa",
    "git.company.com": "/home/username/.ssh/company_deploy",
    "ssh://git.internal.corp": "/home/username/.ssh/internal_key"
  },

  "github.com": "C:\\Users\\username\\.ssh\\github_key.ppk"
}
